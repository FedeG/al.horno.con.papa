{
    "name": "recipebook",
    "version": "2.0.0",
    "private": true,
    "dependencies": {
        "emoji-regex": "^10.6.0",
        "fuse.js": "^7.4.2",
        "glob": "^13.0.6",
        "lucide-react": "^0.294.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-ga4": "^2.1.0",
        "react-helmet-async": "^3.0.0",
        "react-router-dom": "^7.11.0",
        "react-scripts": "5.0.1",
        "react-snap": "^1.23.0",
        "sharp": "^0.34.5"
    },
    "scripts": {
        "start": "react-scripts start",
        "prebuild": "node optimize-images.js",
        "build": "NODE_ENV=production node scripts/generate-sitemap.js && react-scripts build",
        "postbuild": "NODE_ENV=production node scripts/react-snap.js",
        "build:full": "NODE_ENV=production node scripts/generate-sitemap.js && react-scripts build && NODE_ENV=production node scripts/react-snap.js",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "analyze": "npx cra-bundle-analyzer",
        "debug:hydrate": "node scripts/debug-hydration.js"
    },
    "jest": {
        "moduleNameMapper": {
            "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
            "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
            "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
        }
    },
    "reactSnap": {
        "source": "build",
        "destination": "build",
        "fallback": "index.html",
        "include": "./src/data/routes.json",
        "puppeteerArgs": [
            "--no-sandbox",
            "--disable-setuid-sandbox"
        ],
        "inlineCss": true,
        "waitFor": 2000
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "cra-bundle-analyzer": "^0.1.1",
        "express": "^5.2.1",
        "source-map-explorer": "^2.5.3",
        "webpack-bundle-analyzer": "^5.3.0"
    },
    "packageManager": "yarn@4.17.1"
}
