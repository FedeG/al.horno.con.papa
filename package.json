        "react": "^18.2.0",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.2.0",
        "react-ga4": "^2.1.0",
        "react-helmet-async": "^3.0.0",
        "react-router-dom": "^7.11.0",
